# AltairGO Engine — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────

# Direct Supabase PostgreSQL URL (NOT the pooler URL — causes "Tenant not found")
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Redis (local dev: redis://localhost:6379/0)
REDIS_URL=redis://localhost:6379/0

# JWT signing secret — min 32 chars, generate with: openssl rand -hex 32
JWT_SECRET_KEY=replace_with_at_least_32_chars_of_random_string

# Admin panel access key — used for X-Admin-Key header
ADMIN_ACCESS_KEY=replace_with_secure_admin_key

# Google Gemini API key (itinerary polish + embeddings fallback)
GEMINI_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────

# Gemini model override (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Ollama fallback
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2:3b

# Booking.com affiliate ID — enables real hotel links; omit for SimulatedProvider
# BOOKINGCOM_AFFILIATE_ID=

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=https://altairgo.in,http://localhost:5173

# Theme overlap threshold (default: 0.20)
# THEME_THRESHOLD=0.20

# ── Docker / Gunicorn ─────────────────────────────────────────────────────────

# Local postgres service password (Docker Compose only)
DB_PASSWORD=altairgo_dev_pass

# Gunicorn tuning
# GUNICORN_WORKERS=3
# GUNICORN_TIMEOUT=300
# GUNICORN_WORKER_CONNECTIONS=1000
# GUNICORN_MAX_REQUESTS=1000
# GUNICORN_MAX_REQUESTS_JITTER=100

# Log level: debug | info | warning | error
# LOG_LEVEL=info

# ── Local Dev Shortcuts ───────────────────────────────────────────────────────

# DEV_EAGER=true   → run Celery tasks synchronously (no worker needed)
# TESTING=true     → SQLite in-memory DB + disabled rate limiting
# VALIDATION_STRICT=false
